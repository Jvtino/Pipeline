# Pipeline hosted API — environment. Copy to .env and fill in.
# Generate values locally; never commit real secrets.

# ── Required in production ───────────────────────────────────────────────────
# 32-byte base64 master key that wraps mail tokens at rest (envelope encryption).
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PIPELINE_MASTER_KEY=

# Managed Postgres. If unset, the API falls back to in-process PGlite (dev only).
DATABASE_URL=postgres://user:password@host:5432/pipeline

# ── OAuth (YOUR client IDs) — needed to connect real mailboxes ───────────────
# Google "Web application" client (restricted gmail.readonly scope → verification/CASA before public launch).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft "Web" app registration (common tenant — personal or work/school accounts).
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Where the API is reachable (used to build OAuth redirect URIs) and where to send users back.
# Behind Firebase Hosting these are the SAME origin (Hosting rewrites /api+/auth to Cloud Run).
PUBLIC_URL=https://api.yourdomain.com
WEB_URL=https://app.yourdomain.com

# ── Access gate (until a real IdP / Clerk is wired) ──────────────────────────
# Lock a public deployment to known users. Both optional; omit for open local dev.
#   LOGIN_PASSPHRASE — a shared secret required to sign in (only you know it).
#   ALLOWED_EMAILS   — comma-separated allowlist of emails permitted to sign in.
LOGIN_PASSPHRASE=
ALLOWED_EMAILS=

# ── Billing (Merchant of Record: Lemon Squeezy / Paddle) ─────────────────────
# Shared secret to verify webhook HMAC signatures.
BILLING_WEBHOOK_SECRET=
# Ed25519 license keys (PEM). Public verifies in-app; private signs licenses.
#   node -e "const {generateKeyPairSync}=require('crypto');const {publicKey,privateKey}=generateKeyPairSync('ed25519');console.log(publicKey.export({type:'spki',format:'pem'}).toString());console.log(privateKey.export({type:'pkcs8',format:'pem'}).toString())"
PIPELINE_LICENSE_PUBLIC_KEY=
PIPELINE_LICENSE_PRIVATE_KEY=
