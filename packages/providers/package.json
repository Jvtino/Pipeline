{
  "name": "@pipeline/providers",
  "version": "0.1.0",
  "private": true,
  "description": "OAuth (PKCE) + token refresh + Gmail/Graph → unified-thread mappers, in TypeScript. The hosted twin of the desktop gmail.js/msgraph.js and the Python providers.py.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
