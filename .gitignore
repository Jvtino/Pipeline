# Local IMAP credentials — never commit these
.imap_pw
.imap_user
.imap_*

# Local OAuth/IMAP token store written by the web backend (server.py) — never commit
.pipeline-accounts.json

# Local environment / OAuth client credentials (loaded by start.command) — never commit
.env
.env.local
.env.*.local

# Cloud Run env file written during deploy (holds secrets) — never commit
env.yaml

# Firebase project link — created per-user by `firebase use <project-id>`; not committed
.firebaserc

# Local persisted database (PGlite data dir created by start.command) — never commit
.pipeline-data/

# Desktop app (Electron)
node_modules/
dist/
config.json

# macOS + local tooling
.DS_Store
**/.DS_Store
.claude/settings.local.json

# Python bytecode
__pycache__/
*.pyc

# Generated at build time (npm run licenses)
THIRD-PARTY-LICENSES.md
