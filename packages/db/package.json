{
  "name": "@pipeline/db",
  "version": "0.1.0",
  "private": true,
  "description": "Pipeline persistence layer — Drizzle schema + migrations + repository over Postgres. Stores derived application records and ENVELOPE-ENCRYPTED mail tokens (never plaintext). Tested against in-process Postgres (PGlite).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.12",
    "@pipeline/contracts": "workspace:*",
    "@pipeline/crypto": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
