{
  "name": "@pipeline/classify",
  "version": "0.1.0",
  "description": "Pipeline's classifier 'brain': scores email text into a status and resolves the real employer behind ATS platforms. Single source of truth (TypeScript), kept in parity with the frozen legacy classify.js.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "eval": "tsx scripts/eval.ts",
    "try": "tsx scripts/try.ts",
    "add-case": "node scripts/add-case.mjs"
  },
  "dependencies": {
    "@pipeline/contracts": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
